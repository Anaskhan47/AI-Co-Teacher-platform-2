{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "resolveJsonModule": true,

    "declaration": false,
    "sourceMap": false
  },

  "include": [
    "src"
  ],

  "exclude": [
    "dist",
    "node_modules"
  ]
}
