# -----------------------------------------------------------------------------
# AI CO-TEACHER PLATFORM - ENVIRONMENT CONFIGURATION
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# DATABASE & CORE
# -----------------------------------------------------------------------------
PORT=5000
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# AI SERVICES
# -----------------------------------------------------------------------------
# --- DATABASE CONFIGURATION ---
# Use PostgreSQL for Production (Neon, Supabase, etc.)
# DATABASE_URL="postgresql://user:password@host:port/db?sslmode=require"
DATABASE_URL="file:./dev.db"

# --- AUTHENTICATION ---
JWT_SECRET="generate_a_random_secure_string_here"

# --- API KEYS (AI PROVIDERS) ---
GEMINI_API_KEY="your_gemini_key"
GROQ_API_KEY="your_groq_key"

# --- FRONTEND ENVIRONMENT ---
# In Production on Vercel, set this to /api
VITE_API_URL="http://localhost:5000/api"

# --- BACKEND SECURITY ---
# Comma-separated list of allowed origins (no spaces)
# Example: https://app.aicoteacher.com,https://aicoteacher.vercel.app
ALLOWED_ORIGINS="http://localhost:8080,http://localhost:5173"

# --- NODE ENVIRONMENT ---
NODE_ENV="development"
